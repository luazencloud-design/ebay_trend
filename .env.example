# Gemini API ─────────────────────────────────────────────────
# Get one at https://aistudio.google.com/apikey
# Make sure billing is enabled at https://aistudio.google.com/usage
GEMINI_API_KEY=

# Model selection
#   gemini-2.5-pro    → 더 정확, 비용 ~$0.4/day (detail) / ~$6.6/day (full)
#   gemini-2.5-flash  → 빠르고 저렴, 비용 ~$0.013/day (detail) / ~$0.2/day (full)
GEMINI_MODEL=gemini-2.5-pro

# Concurrency limit for parallel calls
# Pro tier on paid plan: 360 RPM, 4M TPM — can safely go up to 8
GEMINI_CONCURRENCY=6
